  updatedAt        DateTime                 @updatedAt

  company        Company?                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  packageVersion PluginMarketplaceVersion @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)
  registryEntry  PluginRegistryEntry?     @relation(fields: [registryEntryId], references: [id], onDelete: SetNull)
  upgradedFrom   PluginInstallation?      @relation("PluginInstallationUpgrade", fields: [upgradedFromId], references: [id], onDelete: SetNull)
  upgrades       PluginInstallation[]     @relation("PluginInstallationUpgrade")

  @@index([companyId])
  @@index([packageVersionId])
  @@index([registryEntryId])
  @@index([status])
  @@index([installedAt])
  @@index([upgradedFromId])
}

