  updatedById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  company            Company?                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  manifest           PluginManifest            @relation(fields: [manifestId], references: [id], onDelete: Cascade)
  lifecycleEvents    PluginLifecycleEvent[]
  eventSubscriptions PluginEventSubscription[]
  hooks              PluginHook[]
  serviceBindings    PluginServiceBinding[]
  permissionGrants   PluginPermissionGrant[]
  configurations     PluginConfiguration[]
  events             PluginEvent[]
  installations      PluginInstallation[]
  sandboxPolicy      PluginSandboxPolicy?
  dependencies       PluginDependency[]
  capabilityGrants   PluginCapabilityGrant[]

  @@unique([companyId, manifestId])
  @@index([companyId])
  @@index([manifestId])
  @@index([status])
  @@index([lifecycle])
  @@index([deletedAt])
}

model PluginLifecycleEvent {
  id              String                @id @default(cuid())
  registryEntryId String
  action          PluginLifecycleAction
  fromState       PluginLifecycleState?
  toState         PluginLifecycleState?
  success         Boolean               @default(true)
  message         String?
  metadata        Json?
  actorId         String?
  createdAt       DateTime              @default(now())

  registryEntry PluginRegistryEntry @relation(fields: [registryEntryId], references: [id], onDelete: Cascade)

  @@index([registryEntryId])
  @@index([action])
  @@index([success])
  @@index([createdAt])
}

model PluginSandboxPolicy {
  id                  String             @id @default(cuid())
  registryEntryId     String             @unique
  level               PluginSandboxLevel @default(ISOLATED)
  allowedCapabilities Json?
  networkPolicy       Json?
  resourceLimits      Json?
  status              PluginStatus       @default(ACTIVE)
  deletedAt           DateTime?
  deletedById         String?
  createdById         String?
  updatedById         String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  registryEntry PluginRegistryEntry @relation(fields: [registryEntryId], references: [id], onDelete: Cascade)

  @@index([level])
  @@index([status])
  @@index([deletedAt])
}

model PluginDependency {
  id              String                 @id @default(cuid())
  registryEntryId String
  dependencyKey   String
  requiredVersion String?
  optional        Boolean                @default(false)
  status          PluginDependencyStatus @default(MISSING)
  resolvedVersion String?
  message         String?
  createdById     String?
  updatedById     String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  registryEntry PluginRegistryEntry @relation(fields: [registryEntryId], references: [id], onDelete: Cascade)

  @@unique([registryEntryId, dependencyKey])
  @@index([registryEntryId])
  @@index([dependencyKey])
  @@index([status])
  @@index([optional])
}

model PluginCapabilityGrant {
  id              String               @id @default(cuid())
  registryEntryId String
  capability      PluginCapabilityType
  status          PluginStatus         @default(ACTIVE)
  constraints     Json?
  deletedAt       DateTime?
  deletedById     String?
  createdById     String?
  updatedById     String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  registryEntry PluginRegistryEntry @relation(fields: [registryEntryId], references: [id], onDelete: Cascade)

  @@unique([registryEntryId, capability])
  @@index([registryEntryId])
  @@index([capability])
  @@index([status])
  @@index([deletedAt])
}

model PluginMarketplacePackage {
  id          String       @id @default(cuid())
  companyId   String?
  packageKey  String
  name        String
  publisher   String?
  summary     String?
  websiteUrl  String?
  status      PluginStatus @default(DRAFT)
  metadata    Json?
  deletedAt   DateTime?
  deletedById String?
  createdById String?
  updatedById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company  Company?                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  versions PluginMarketplaceVersion[]

  @@unique([companyId, packageKey])
  @@index([companyId])
  @@index([packageKey])
  @@index([publisher])
  @@index([status])
  @@index([deletedAt])
}

model PluginMarketplaceVersion {
  id            String       @id @default(cuid())
  packageId     String
  manifestId    String?
  version       String
  releaseNotes  String?
  compatibility Json?
  checksum      String?
  status        PluginStatus @default(DRAFT)
  metadata      Json?
  createdById   String?
  updatedById   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  package       PluginMarketplacePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  manifest      PluginManifest?          @relation(fields: [manifestId], references: [id], onDelete: SetNull)
  installations PluginInstallation[]

  @@unique([packageId, version])
  @@index([packageId])
  @@index([manifestId])
  @@index([version])
  @@index([status])
}

model PluginInstallation {
  id               String                   @id @default(cuid())
  companyId        String?
  packageVersionId String
  registryEntryId  String?
  status           PluginInstallationStatus @default(INSTALLED)
  installedAt      DateTime                 @default(now())
  enabledAt        DateTime?
  disabledAt       DateTime?
  uninstalledAt    DateTime?
  upgradedFromId   String?
  config           Json?
  createdById      String?
  updatedById      String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  company        Company?                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  packageVersion PluginMarketplaceVersion @relation(fields: [packageVersionId], references: [id], onDelete: Cascade)
  registryEntry  PluginRegistryEntry?     @relation(fields: [registryEntryId], references: [id], onDelete: SetNull)
  upgradedFrom   PluginInstallation?      @relation("PluginInstallationUpgrade", fields: [upgradedFromId], references: [id], onDelete: SetNull)
  upgrades       PluginInstallation[]     @relation("PluginInstallationUpgrade")

  @@index([companyId])
  @@index([packageVersionId])
  @@index([registryEntryId])
  @@index([status])
  @@index([installedAt])
  @@index([upgradedFromId])
}

model PluginEventSubscription {
  id              String       @id @default(cuid())
  registryEntryId String
  eventName       String
  filter          Json?
  status          PluginStatus @default(ACTIVE)
  deletedAt       DateTime?
  deletedById     String?
  createdById     String?
  updatedById     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  registryEntry PluginRegistryEntry @relation(fields: [registryEntryId], references: [id], onDelete: Cascade)

  @@unique([registryEntryId, eventName])
  @@index([registryEntryId])
  @@index([eventName])
  @@index([status])
  @@index([deletedAt])
}

