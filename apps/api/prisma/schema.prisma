model User {
  id                String     @id @default(cuid())
  username          String     @unique
  email             String     @unique
  password          String
  fullName          String
  phone             String?
  avatar            String?
  status            UserStatus @default(ACTIVE)
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  roles                   UserRole[]
  createdLogs             AuditLog[]               @relation("CreatedBy")
  employee                Employee?
  leaveApprovals          LeaveApproval[]          @relation("LeaveApprovalApprover")
  reviewedPayrollRuns     PayrollRun[]             @relation("PayrollRunReviewedBy")
  approvedPayrollRuns     PayrollRun[]             @relation("PayrollRunApprovedBy")
  workflowDefinitionSteps WorkflowDefinitionStep[]
  mobileDevices           MobileDevice[]
  mobileSessions          MobileSession[]
  mobilePushNotifications MobilePushNotification[]
  mobileSyncCursors       MobileSyncCursor[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users                   UserRole[]
  permissions             RolePermission[]
  workflowDefinitionSteps WorkflowDefinitionStep[]
}

model Permission {
  id          String  @id @default(cuid())
  module      String
  action      String
  code        String  @unique
  description String?

  roles RolePermission[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Company {
  id                     String             @id @default(cuid())
  tenantId               String?
  code                   String             @unique
  name                   String
  legalName              String?
  commercialRegistration String?
  taxNumber              String?
  phone                  String?
  email                  String?
  website                String?
  address                String?
  city                   String?
  country                String?
  status                 OrganizationStatus @default(ACTIVE)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  tenant                     Tenant?                       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  branches                   Branch[]
  departments                Department[]
  positions                  Position[]
  costCenters                CostCenter[]
  employees                  Employee[]
  shifts                     Shift[]
  holidays                   Holiday[]
  leaveTypes                 LeaveType[]
  leaveBalances              LeaveBalance[]
  salaryComponents           SalaryComponent[]
  payrollPeriods             PayrollPeriod[]
  payrollRuns                PayrollRun[]
  accounts                   Account[]
  journalEntries             JournalEntry[]
  reportCategories           ReportCategory[]
  reportDefinitions          ReportDefinition[]
  reportExecutions           ReportExecution[]
  jobPositions               JobPosition[]
  vacancies                  Vacancy[]
  performanceCycles          PerformanceCycle[]
  assetCategories            AssetCategory[]
  assets                     Asset[]
  documentCategories         DocumentCategory[]
  documents                  Document[]
  selfServiceRequests        SelfServiceRequest[]
  notifications              Notification[]
  workflowDefinitions        WorkflowDefinition[]
  businessRuleCategories     BusinessRuleCategory[]
  businessRules              BusinessRule[]
  businessRuleExecutions     BusinessRuleExecution[]
  aiProviderConfigs          AiProviderConfig[]
  aiRequestLogs              AiRequestLog[]
  aiUsageRecords             AiUsageRecord[]
  aiUsageLimits              AiUsageLimit[]
  aiSafetyPolicies           AiSafetyPolicy[]
  integrationProviders       IntegrationProvider[]
  integrationCredentials     IntegrationCredential[]
  integrationConnections     IntegrationConnection[]
  integrationWebhooks        IntegrationWebhook[]
  integrationRestConnectors  IntegrationRestConnector[]
  integrationRetryPolicies   IntegrationRetryPolicy[]
  integrationOutboundJobs    IntegrationOutboundJob[]
  integrationInboundEvents   IntegrationInboundEvent[]
  integrationExecutions      IntegrationExecutionHistory[]
  integrationHealthSnapshots IntegrationHealthSnapshot[]
  pluginManifests            PluginManifest[]
  pluginRegistryEntries      PluginRegistryEntry[]
  pluginMarketplacePackages  PluginMarketplacePackage[]
  pluginInstallations        PluginInstallation[]
  mobileDevices              MobileDevice[]
  mobileSessions             MobileSession[]
  mobileSyncCursors          MobileSyncCursor[]
  mobileSyncChanges          MobileSyncChange[]
  searchIndexes              SearchIndex[]
  searchQueryLogs            SearchQueryLog[]
  biKpiDefinitions           BiKpiDefinition[]
  biKpiSnapshots             BiKpiSnapshot[]
  biDatasets                 BiDataset[]
  biMetricDefinitions        BiMetricDefinition[]
  biMetricObservations       BiMetricObservation[]
  biAnalyticsExecutions      BiAnalyticsExecution[]

  @@index([status])
  @@index([tenantId])
}

model Tenant {
  id            String       @id @default(cuid())
  code          String       @unique
  name          String
  legalName     String?
  status        TenantStatus @default(PROVISIONING)
  plan          TenantPlan   @default(STARTER)
  primaryDomain String?
  metadata      Json?
  deletedAt     DateTime?
  deletedById   String?
  createdById   String?
  updatedById   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  companies                      Company[]
  branches                       Branch[]
  domains                        TenantDomain[]
  settings                       TenantSetting[]
  flags                          TenantFeatureFlag[]
  locales                        TenantLocalization[]
  branding                       TenantBranding?
  limits                         TenantUsageLimit[]
  events                         TenantProvisioningEvent[]
  policies                       TenantPermissionPolicy[]
  audits                         TenantAuditEvent[]
  apiGroups                      PublicApiGroup[]
  apis                           PublicApiRegistry[]
  apiApplications                PublicApiApplication[]
  apiKeys                        PublicApiKey[]
  apiRateLimitPolicies           PublicApiRateLimitPolicy[]
  apiUsageCounters               PublicApiUsageCounter[]
  apiRequestLogs                 PublicApiRequestLog[]
  apiSignatureNonces             PublicApiSignatureNonce[]
  observabilityProviders         ObservabilityHealthProvider[]
  observabilityChecks            ObservabilityHealthCheckResult[]
  observabilityMetricDefinitions ObservabilityMetricDefinition[]
  observabilityMetricSamples     ObservabilityMetricSample[]
  observabilityLogs              ObservabilityLogEntry[]
  observabilityTraces            ObservabilityTrace[]
  observabilitySpans             ObservabilitySpan[]
  schedulerCrons                 SchedulerCronRegistry[]
  schedulerJobs                  SchedulerScheduledJob[]
  schedulerJobHistories          SchedulerJobHistory[]
  schedulerRecoveries            SchedulerFailureRecovery[]
  mobileDevices                  MobileDevice[]
  mobileSessions                 MobileSession[]
  mobilePushNotifications        MobilePushNotification[]
  mobileSyncCursors              MobileSyncCursor[]
  mobileSyncChanges              MobileSyncChange[]
  searchIndexes                  SearchIndex[]
  searchQueryLogs                SearchQueryLog[]
  biKpiDefinitions               BiKpiDefinition[]
  biKpiSnapshots                 BiKpiSnapshot[]
  biDatasets                     BiDataset[]
  biMetricDefinitions            BiMetricDefinition[]
  biMetricObservations           BiMetricObservation[]
  biAnalyticsExecutions          BiAnalyticsExecution[]

  @@index([code])
  @@index([status])
  @@index([plan])
  @@index([primaryDomain])
  @@index([deletedAt])
}

model TenantDomain {
  id          String    @id @default(cuid())
  tenantId    String
  domain      String    @unique
  isPrimary   Boolean   @default(false)
  verifiedAt  DateTime?
  deletedAt   DateTime?
  deletedById String?
  createdById String?
  updatedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([domain])
  @@index([isPrimary])
  @@index([deletedAt])
}

model TenantSetting {
  id          String                    @id @default(cuid())
  tenantId    String
  key         String
  value       Json?
  isSecret    Boolean                   @default(false)
  secretRef   String?
  status      TenantConfigurationStatus @default(ACTIVE)
  deletedAt   DateTime?
  deletedById String?
  createdById String?
  updatedById String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([key])
  @@index([status])
  @@index([deletedAt])
}

model TenantFeatureFlag {
  id          String                    @id @default(cuid())
  tenantId    String
  key         String
  enabled     Boolean                   @default(false)
  config      Json?
  status      TenantConfigurationStatus @default(ACTIVE)
  deletedAt   DateTime?
  deletedById String?
  createdById String?
  updatedById String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([key])
  @@index([enabled])
  @@index([status])
  @@index([deletedAt])
}

model TenantLocalization {
  id          String                    @id @default(cuid())
  tenantId    String
  locale      String
  timezone    String?
  dateFormat  String?
  timeFormat  String?
  currency    String?
  status      TenantConfigurationStatus @default(ACTIVE)
  deletedAt   DateTime?
  deletedById String?
  createdById String?
  updatedById String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, locale])
  @@index([tenantId])
  @@index([locale])
  @@index([status])
  @@index([deletedAt])
}

model TenantBranding {
  id             String                    @id @default(cuid())
  tenantId       String                    @unique
  brandName      String?
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  metadata       Json?
  status         TenantConfigurationStatus @default(ACTIVE)
  deletedAt      DateTime?
  deletedById    String?
  createdById    String?
  updatedById    String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([deletedAt])
}

model TenantUsageLimit {
  id           String                    @id @default(cuid())
  tenantId     String
  key          String
  limitValue   Int
  currentValue Int                       @default(0)
  period       TenantUsagePeriod         @default(MONTHLY)
  status       TenantConfigurationStatus @default(ACTIVE)
  deletedAt    DateTime?
  deletedById  String?
  createdById  String?
  updatedById  String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key, period])
  @@index([tenantId])
  @@index([key])
  @@index([period])
  @@index([status])
  @@index([deletedAt])
}

model TenantProvisioningEvent {
  id        String                   @id @default(cuid())
  tenantId  String
  action    TenantProvisioningAction
  status    TenantProvisioningStatus @default(PENDING)
  reason    String?
  payload   Json?
  actorId   String?
