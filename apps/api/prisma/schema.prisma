  isSecret        Boolean      @default(false)
  secretRef       String?
  status          PluginStatus @default(ACTIVE)
  deletedAt       DateTime?
  deletedById     String?
  createdById     String?
  updatedById     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  registryEntry PluginRegistryEntry @relation(fields: [registryEntryId], references: [id], onDelete: Cascade)

  @@unique([registryEntryId, key])
