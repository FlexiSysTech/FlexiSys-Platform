model User {
  id                String     @id @default(cuid())
  username          String     @unique
  email             String     @unique
  password          String
  fullName          String
  phone             String?
  avatar            String?
  status            UserStatus @default(ACTIVE)
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  roles                   UserRole[]
  createdLogs             AuditLog[]               @relation("CreatedBy")
  employee                Employee?
  leaveApprovals          LeaveApproval[]          @relation("LeaveApprovalApprover")
  reviewedPayrollRuns     PayrollRun[]             @relation("PayrollRunReviewedBy")
  approvedPayrollRuns     PayrollRun[]             @relation("PayrollRunApprovedBy")
  workflowDefinitionSteps WorkflowDefinitionStep[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users                   UserRole[]
  permissions             RolePermission[]
  workflowDefinitionSteps WorkflowDefinitionStep[]
}

model Permission {
  id          String  @id @default(cuid())
  module      String
  action      String
  code        String  @unique
  description String?

  roles RolePermission[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Company {
  id                     String             @id @default(cuid())
  tenantId               String?
  code                   String             @unique
  name                   String
  legalName              String?
  commercialRegistration String?
  taxNumber              String?
  phone                  String?
  email                  String?
  website                String?
  address                String?
  city                   String?
  country                String?
  status                 OrganizationStatus @default(ACTIVE)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  tenant                     Tenant?                       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  branches                   Branch[]
  departments                Department[]
  positions                  Position[]
  costCenters                CostCenter[]
  employees                  Employee[]
  shifts                     Shift[]
  holidays                   Holiday[]
  leaveTypes                 LeaveType[]
  leaveBalances              LeaveBalance[]
  salaryComponents           SalaryComponent[]
  payrollPeriods             PayrollPeriod[]
  payrollRuns                PayrollRun[]
  accounts                   Account[]
  journalEntries             JournalEntry[]
  reportCategories           ReportCategory[]
  reportDefinitions          ReportDefinition[]
  reportExecutions           ReportExecution[]
  jobPositions               JobPosition[]
  vacancies                  Vacancy[]
  performanceCycles          PerformanceCycle[]
  assetCategories            AssetCategory[]
  assets                     Asset[]
  documentCategories         DocumentCategory[]
  documents                  Document[]
  selfServiceRequests        SelfServiceRequest[]
  notifications              Notification[]
  workflowDefinitions        WorkflowDefinition[]
  businessRuleCategories     BusinessRuleCategory[]
  businessRules              BusinessRule[]
  businessRuleExecutions     BusinessRuleExecution[]
  aiProviderConfigs          AiProviderConfig[]
  aiRequestLogs              AiRequestLog[]
  aiUsageRecords             AiUsageRecord[]
  aiUsageLimits              AiUsageLimit[]
  aiSafetyPolicies           AiSafetyPolicy[]
  integrationProviders       IntegrationProvider[]
  integrationCredentials     IntegrationCredential[]
  integrationConnections     IntegrationConnection[]
  integrationWebhooks        IntegrationWebhook[]
  integrationRestConnectors  IntegrationRestConnector[]
  integrationRetryPolicies   IntegrationRetryPolicy[]
  integrationOutboundJobs    IntegrationOutboundJob[]
  integrationInboundEvents   IntegrationInboundEvent[]
  integrationExecutions      IntegrationExecutionHistory[]
  integrationHealthSnapshots IntegrationHealthSnapshot[]
  pluginManifests            PluginManifest[]
  pluginRegistryEntries      PluginRegistryEntry[]
  pluginMarketplacePackages  PluginMarketplacePackage[]
  pluginInstallations        PluginInstallation[]

  @@index([status])
  @@index([tenantId])
}

model Tenant {
  id            String       @id @default(cuid())
  code          String       @unique
  name          String
  legalName     String?
  status        TenantStatus @default(PROVISIONING)
  plan          TenantPlan   @default(STARTER)
  primaryDomain String?
  metadata      Json?
  deletedAt     DateTime?
  deletedById   String?
  createdById   String?
  updatedById   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  companies Company[]
  branches  Branch[]
  domains   TenantDomain[]

  @@index([code])
  @@index([status])
  @@index([plan])
  @@index([primaryDomain])
  @@index([deletedAt])
}

model TenantDomain {
  id          String    @id @default(cuid())
  tenantId    String
  domain      String    @unique
  isPrimary   Boolean   @default(false)
  verifiedAt  DateTime?
  deletedAt   DateTime?
  deletedById String?
  createdById String?
  updatedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([domain])
  @@index([isPrimary])
  @@index([deletedAt])
}

model Account {
  id          String        @id @default(cuid())
  companyId   String
  parentId    String?
  code        String
  name        String
  type        AccountType
  status      AccountStatus @default(ACTIVE)
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   Account?           @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Account[]          @relation("AccountHierarchy")
  lines    JournalEntryLine[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([parentId])
  @@index([type])
  @@index([status])
}

model JournalEntry {
  id          String             @id @default(cuid())
  companyId   String
  entryNumber String
  entryDate   DateTime
  description String?
  status      JournalEntryStatus @default(DRAFT)
  source      JournalEntrySource @default(MANUAL)
  sourceRef   String?
  totalDebit  Decimal            @default(0) @db.Decimal(14, 2)
  totalCredit Decimal            @default(0) @db.Decimal(14, 2)
  postedAt    DateTime?
  voidedAt    DateTime?
  createdById String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   JournalEntryLine[]

  @@unique([companyId, entryNumber])
  @@index([companyId])
  @@index([entryDate])
  @@index([status])
  @@index([source])
  @@index([sourceRef])
}

model JournalEntryLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal  @default(0) @db.Decimal(14, 2)
  credit         Decimal  @default(0) @db.Decimal(14, 2)
  description    String?
  employeeId     String?
  departmentId   String?
  branchId       String?
  costCenterId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  employee     Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  costCenter   CostCenter?  @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([employeeId])
  @@index([departmentId])
  @@index([branchId])
  @@index([costCenterId])
}

model ReportCategory {
  id          String   @id @default(cuid())
  companyId   String?
  code        String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company?           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  definitions ReportDefinition[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([code])
}

model ReportDefinition {
  id          String                 @id @default(cuid())
  companyId   String?
  categoryId  String?
  code        String
  name        String
  description String?
  module      String
  handler     String
  status      ReportDefinitionStatus @default(ACTIVE)
  isSystem    Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  company    Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category   ReportCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parameters ReportParameter[]
  executions ReportExecution[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([categoryId])
  @@index([module])
  @@index([handler])
  @@index([status])
}

model ReportParameter {
  id           String              @id @default(cuid())
  reportId     String
  code         String
  label        String
  type         ReportParameterType
  isRequired   Boolean             @default(false)
  defaultValue String?
  options      Json?
  displayOrder Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  report ReportDefinition @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, code])
  @@index([reportId])
  @@index([type])
}

model ReportExecution {
  id           String                @id @default(cuid())
  companyId    String?
  reportId     String?
  handler      String
  status       ReportExecutionStatus @default(PENDING)
  format       ReportExportFormat    @default(JSON)
  parameters   Json?
  rowCount     Int                   @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  error        String?
  executedById String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  company Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  report  ReportDefinition? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([reportId])
  @@index([handler])
  @@index([status])
  @@index([format])
  @@index([createdAt])
}

model Branch {
  id        String             @id @default(cuid())
  tenantId  String?
  companyId String
  code      String
  name      String
  phone     String?
  email     String?
  address   String?
  city      String?
  country   String?
  status    OrganizationStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  tenant            Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments       Department[]
  costCenters       CostCenter[]
  employees         Employee[]
  shifts            Shift[]
  holidays          Holiday[]
  journalEntryLines JournalEntryLine[]
  businessRules     BusinessRule[]

  @@unique([companyId, code])
  @@index([tenantId])
  @@index([companyId])
  @@index([status])
}

model Department {
  id          String             @id @default(cuid())
  companyId   String
  branchId    String?
  parentId    String?
  code        String
  name        String
  description String?
  status      OrganizationStatus @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch            Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  parent            Department?        @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Department[]       @relation("DepartmentHierarchy")
  positions         Position[]
  employees         Employee[]
  journalEntryLines JournalEntryLine[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
  @@index([parentId])
  @@index([status])
}

model Position {
  id           String             @id @default(cuid())
  companyId    String
  departmentId String?
  code         String
  title        String
  description  String?
  status       OrganizationStatus @default(ACTIVE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees  Employee[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([departmentId])
  @@index([status])
}

model CostCenter {
  id          String             @id @default(cuid())
  companyId   String
  branchId    String?
  code        String
  name        String
  description String?
  status      OrganizationStatus @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch            Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  employees         Employee[]
  journalEntryLines JournalEntryLine[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
  @@index([status])
}

model Employee {
  id             String  @id @default(cuid())
  employeeNumber String
  userId         String? @unique

  companyId    String
  branchId     String?
  departmentId String?
  positionId   String?
  costCenterId String?

  firstName  String
  middleName String?
  lastName   String
  fullName   String

  nationalId     String?
  passportNumber String?
  gender         Gender?
  dateOfBirth    DateTime?
  nationality    String?

  phone   String?
  email   String?
  address String?

  hireDate         DateTime
  probationEndDate DateTime?
  terminationDate  DateTime?

  employmentType EmploymentType @default(FULL_TIME)
  status         EmployeeStatus @default(ACTIVE)

  basicSalary        Decimal? @db.Decimal(12, 2)
  housingAllowance   Decimal? @db.Decimal(12, 2)
  transportAllowance Decimal? @db.Decimal(12, 2)
  otherAllowance     Decimal? @db.Decimal(12, 2)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch     Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position   Position?   @relation(fields: [positionId], references: [id], onDelete: SetNull)
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  shiftAssignments          EmployeeShiftAssignment[]
  attendanceRecords         AttendanceRecord[]
  leaveBalances             LeaveBalance[]
  leaveRequests             LeaveRequest[]
  payrollProfiles           PayrollProfile[]
  payrollItems              PayrollItem[]
  payslips                  Payslip[]
  journalEntryLines         JournalEntryLine[]
  jobApplications           JobApplication[]
  interviews                Interview[]
  interviewEvaluations      InterviewEvaluation[]     @relation("InterviewEvaluationEvaluator")
